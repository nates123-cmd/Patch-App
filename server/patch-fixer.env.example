# Patch fixer — env. Copy to patch-fixer.env on the Beelink (chmod 600) and fill in.
# Reuses the same Supabase project + service key as the Port daemon (~/port/port-server.env).

SUPABASE_URL=https://xsmnfcmtbpeaccnyinkr.supabase.co
SUPABASE_SERVICE_KEY=       # service_role key (from ~/port/port-server.env)
OWNER_ID=24c79501-4011-46c9-a3d3-a716d732d69c

GH_OWNER=nates123-cmd
CODE_DIR=/home/nate/code
CLAUDE_BIN=/home/nate/.local/bin/claude
PERMISSION_MODE=bypassPermissions

# Kill switch. Daemon idles until this is exactly "true".
ENABLED=false

# Port handoff for COMPLEX / un-shippable items: the daemon opens a phone-
# driveable Port session and pings the phone. Reuse the same push secret the
# Port daemon uses (from ~/port/port-server.env, PORT_PUSH_SECRET). If unset,
# escalations still create the Port session — only the push notification no-ops.
PORT_PUSH_SECRET=
# PORT_PUSH_URL=   # defaults to <SUPABASE_URL>/functions/v1/port-push
# NOTIFY_SHIPS=true   # also push a "Shipped" ping on clean auto-ships (default true)

POLL_MS=15000
MAX_ITEM_MS=1500000
